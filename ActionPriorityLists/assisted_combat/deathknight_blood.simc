
# Executed before combat begins. Accepts non-harmful actions only.
actions.precombat=snapshot_stats

# Executed every time the actor is available.
actions=auto_attack
actions+=/call_action_list,name=cooldowns
actions+=/call_action_list,name=assisted_combat

# This is the default action priority list from the game's Assisted Combat system.
actions.assisted_combat=dancing_rune_weapon,can_have_one_button_penalty=1,if=target.distance<=15
actions.assisted_combat+=/bonestorm,can_have_one_button_penalty=1,if=active_enemies>1&buff.bone_shield.stack>=5
actions.assisted_combat+=/reapers_mark,can_have_one_button_penalty=1,if=debuff.reapers_mark_debuff.down
actions.assisted_combat+=/marrowrend,can_have_one_button_penalty=1,if=buff.bone_shield.stack<=6
actions.assisted_combat+=/marrowrend,can_have_one_button_penalty=1,if=buff.bone_shield.down
actions.assisted_combat+=/marrowrend,can_have_one_button_penalty=1,if=buff.exterminate.up
actions.assisted_combat+=/soul_reaper,can_have_one_button_penalty=1,if=buff.reaper_of_souls.up
actions.assisted_combat+=/death_and_decay,can_have_one_button_penalty=1,if=target.distance<=10&buff.death_and_decay.down
actions.assisted_combat+=/heart_strike,can_have_one_button_penalty=1,if=buff.gift_of_the_sanlayn.up
actions.assisted_combat+=/heart_strike,can_have_one_button_penalty=1,if=buff.vampiric_strike.up
actions.assisted_combat+=/consumption,can_have_one_button_penalty=1,if=target.distance<=5
actions.assisted_combat+=/soul_reaper,can_have_one_button_penalty=1,if=target.health.pct<=35
actions.assisted_combat+=/blood_boil,can_have_one_button_penalty=1,if=target.distance<=10
actions.assisted_combat+=/death_strike,can_have_one_button_penalty=1,if=runic_power>=80
actions.assisted_combat+=/blooddrinker,can_have_one_button_penalty=1
actions.assisted_combat+=/heart_strike,can_have_one_button_penalty=1
actions.assisted_combat+=/deaths_caress,can_have_one_button_penalty=1
actions.assisted_combat+=/heart_strike,can_have_one_button_penalty=1

# Major cooldowns are not used by the Assisted Combat system. This simple default cooldown usage has been provided by simc.
actions.cooldowns=use_items
actions.cooldowns+=/potion
actions.cooldowns+=/blood_fury
actions.cooldowns+=/berserking
actions.cooldowns+=/fireblood
actions.cooldowns+=/ancestral_call
actions.cooldowns+=/vampiric_blood
actions.cooldowns+=/tombstone,if=buff.bone_shield.stack>5
actions.cooldowns+=/abomination_limb
actions.cooldowns+=/raise_dead
